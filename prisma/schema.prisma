// Dorea Network — MVP Data Model
// Moment 1: Request submission + acknowledgment
// Later moments add: Assignment, FollowUp, Escalation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Community {
  id          String   @id @default(uuid())
  name        String
  invite_code String   @unique
  status      String   @default("active")
  created_at  DateTime @default(now())

  members      Member[]
  requests     Request[]
  audit_events AuditEvent[]
}

model Member {
  id                   String   @id @default(uuid())
  community_id         String
  first_name           String
  last_name            String
  email                String   @unique
  password_hash        String
  phone                String?
  role                 String   @default("member")
  status               String   @default("active")
  onboarding_accepted  Boolean  @default(false)
  notification_sms     Boolean  @default(true)
  notification_email   Boolean  @default(true)
  notification_push    Boolean  @default(true)
  created_at           DateTime @default(now())

  community    Community    @relation(fields: [community_id], references: [id])
  requests     Request[]
  audit_events AuditEvent[]
}

model Request {
  id                    String    @id @default(uuid())
  community_id          String
  member_id             String
  request_type          String
  title                 String
  description           String?
  urgency_level         String    @default("medium")
  visibility_level      String    @default("leaders")
  status                String    @default("open")
  acknowledgment_status String    @default("pending")
  assigned_member_id    String?
  created_at            DateTime  @default(now())
  acknowledged_at       DateTime?
  resolved_at           DateTime?
  last_follow_up_at     DateTime?

  community    Community    @relation(fields: [community_id], references: [id])
  member       Member       @relation(fields: [member_id], references: [id])
  audit_events AuditEvent[]
}

model AuditEvent {
  id           String   @id @default(uuid())
  community_id String
  request_id   String?
  member_id    String
  event_type   String
  event_data   String?
  created_at   DateTime @default(now())

  community Community @relation(fields: [community_id], references: [id])
  member    Member     @relation(fields: [member_id], references: [id])
  request   Request?   @relation(fields: [request_id], references: [id])
}
